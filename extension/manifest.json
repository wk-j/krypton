{
  "manifest_version": 3,
  "name": "Krypton Harness",
  "version": "0.1.0",
  "description": "Send the current page selection to a Krypton harness lane as a chosen action.",
  "key": "",
  "permissions": ["nativeMessaging", "activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:8766/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Krypton Harness", "default_popup": "popup.html" },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["github-issue.js"],
      "css": ["github-issue.css"],
      "run_at": "document_idle"
    }
  ]
}
